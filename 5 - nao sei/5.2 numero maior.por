programa {
  funcao inicio() {
    inteiro num1,num2
    escreva("Primeiro numero:")
    leia(num1)
    escreva("Segundo numero:")
    leia(num2)
    se(num1>num2){
      escreva(num1, " é maior que ", num2)
    }
    se(num2>num1){
      escreva(num2," é maior que ", num1)
     }
    se (num1 == num2){ 
      escreva("Os dois numeros tem o mesmo valor")
    }
    }
  }

